<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>CivicPulse – Smart Complaint System</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<style>
/* BODY & BACKGROUND */
body { 
  font-family: 'Segoe UI', sans-serif; 
  margin:0; 
  color: #1a1a1a;
  background: url('https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=1950&q=80') no-repeat center center fixed; 
  background-size: cover;
}

/* NAVBAR */
.navbar { 
  background: rgba(34,139,34,0.85); /* Forest green semi-transparent */ 
  padding:20px; 
  text-align:center; 
  font-size:26px; 
  font-weight:bold; 
  color:white; 
  box-shadow: 0 4px 8px rgba(0,0,0,0.3);
  border-bottom-left-radius:20px;
  border-bottom-right-radius:20px;
}

/* CONTAINER CARD */
.container { 
  max-width:900px; 
  margin:auto; 
  padding:20px; 
}

/* CARD STYLING */
.card { 
  background: rgba(255,255,255,0.85); 
  padding:20px; 
  border-radius:20px; 
  margin-bottom:20px; 
  box-shadow: 0 8px 16px rgba(0,0,0,0.2);
  color: #1a1a1a;
  transition: transform 0.3s;
}
.card:hover { transform: translateY(-5px); }

/* INPUTS, TEXTAREA & SELECT */
input, textarea, select { 
  width:100%; 
  padding:12px; 
  margin:8px 0; 
  border-radius:12px; 
  border:1px solid #28a745; 
  outline:none; 
  font-size:16px;
  background: #f9f9f9;
  transition: all 0.3s;
}
input:focus, textarea:focus, select:focus { 
  border: 2px solid #1e7e34; 
  box-shadow: 0 0 5px #28a745; 
}

/* BUTTONS */
button { 
  padding:10px 18px; 
  margin:5px 0; 
  border-radius:12px; 
  border:none; 
  cursor:pointer; 
  font-weight:bold;
  transition: all 0.3s;
}
.btn-blue { background:#28a745; color:white; }
.btn-blue:hover { background:#1e7e34; }
.btn-green { background:#a8e6cf; color:#1a1a1a; }
.btn-green:hover { background:#81c784; }
.btn-yellow { background:#fff176; color:#1a1a1a; }
.btn-yellow:hover { background:#fdd835; }
.voice-btn { background:#66bb6a; color:white; margin-left:5px; }
.voice-btn:hover { background:#43a047; }

/* GRID STATS */
.grid { display:grid; grid-template-columns:repeat(4,1fr); gap:15px; margin-top:20px; }
.stat { padding:15px; border-radius:15px; text-align:center; font-weight:bold; font-size:16px; box-shadow: 0 4px 8px rgba(0,0,0,0.2); }
.pending { background:#ffcc80; color:#4e342e; }
.escalated { background:#ff8a65; color:white; }
.resolved { background:#81c784; color:white; }
.reopened { background:#4fc3f7; color:white; }

/* MAP */
#map { height:400px; border-radius:15px; margin-top:15px; box-shadow: 0 8px 16px rgba(0,0,0,0.3); }

/* DATA TABLE */
.data-table { width:100%; border-collapse:collapse; margin-top:10px; font-size:16px; background: rgba(255,255,255,0.9); border-radius:10px; overflow:hidden; }
.data-table th, .data-table td { padding:12px; text-align:center; }
.data-table th { background:#28a745; color:white; font-size:16px; }
.high-risk { background: rgba(255,0,0,0.2); color:red; font-weight:bold; }
.medium-risk { background: rgba(255,255,0,0.2); color:orange; font-weight:bold; }
.low-risk { background: rgba(0,255,0,0.2); color:green; font-weight:bold; }

/* PAGE SWITCH */
.page { display:none; } 
.active { display:block; }

/* PHOTO PREVIEW */
.photo-preview { max-height:180px; margin-top:10px; border-radius:12px; display:none; box-shadow: 0 4px 8px rgba(0,0,0,0.2); }

/* BUTTON HOVER EFFECT */
button:hover { transform: scale(1.05); }

/* H3 HEADERS */
h3 { color:#1e7e34; }  

/* Chat UI */
#chatContainer { max-height:300px; overflow-y:auto; padding:10px; background: rgba(255,255,255,0.1); border-radius:10px; margin-top:10px; }
.bubble { padding:8px 12px; margin:5px; border-radius:15px; max-width:80%; }
.user { background:#28a745; color:white; align-self:flex-end; }
.ai { background:white; color:#333; align-self:flex-start; }
</style>
</head>
<body>

<div class="navbar">CivicPulse – Smart Complaint System</div>

<!-- HOME PAGE -->
<div id="homePage" class="page active">
  <div class="container">
    <div class="card">
      <h3>Report Complaint</h3>
      <input id="title" placeholder="Problem Title">
      <button class="voice-btn" onclick="startVoice('title')">🎤</button>

      <textarea id="desc" placeholder="Description"></textarea>
      <button class="voice-btn" onclick="startVoice('desc')">🎤</button>

      <input type="file" id="photoInput" accept="image/*">
      <img id="photoPreview" class="photo-preview">

      <select id="locationSource">
        <option value="current">Use Current GPS Location</option>
        <option value="manual">Enter Location Manually</option>
      </select>
      <input id="manualLocation" placeholder="Manual Location (if selected)" style="display:none;">

      <button class="btn-blue" onclick="addComplaint()">Submit Complaint</button>
      <button class="btn-green" onclick="openMapPage()">📊 View Map & Data</button>
    </div>

    <div class="grid">
      <div class="stat pending">Pending: <span id="pending">0</span></div>
      <div class="stat escalated">Escalated: <span id="escalated">0</span></div>
      <div class="stat resolved">Resolved: <span id="resolved">0</span></div>
      <div class="stat reopened">Reopened: <span id="reopened">0</span></div>
    </div>

    <div id="list"></div>
  </div>
</div> 

<div class="card">
    <h3>AI Assistant</h3>
    <div id="chatContainer"></div>
    <input id="chatInput" placeholder="Ask me something..." onkeydown="if(event.key==='Enter') sendMessage()">
    <button onclick="sendMessage()" class="btn-blue">Send</button>
</div> 

<!-- MAP + DATA PAGE -->
<div id="mapPage" class="page">
  <div class="container">
    <button onclick="goHome()">⬅ Back</button>

    <div class="card">
      <h3>Historical Impact Data</h3>
      <table class="data-table">
        <thead>
          <tr><th>Issue / Disease</th><th>Cost Loss (₹)</th><th>Affected People</th></tr>
        </thead>
        <tbody id="dataBody"></tbody>
      </table>
    </div>

    <h3>Map Zone</h3>
    <div id="map"></div>
  </div>
</div>

<script> 

let role = localStorage.getItem("userRole");

if(!role){
  window.location.href = "login.html";
} 


// INITIAL DATA
let complaints = JSON.parse(localStorage.getItem("complaints")) || [];
let stats = { "Dengue": {cost:5000000, people:1200}, "Flood": {cost:20000000, people:5000},
              "Water": {cost:3000000, people:2000}, "Garbage": {cost:500000, people:300},
              "Street": {cost:200000, people:150}, "Pothole": {cost:300000, people:200} };

// MAP
let map = L.map('map').setView([13.0827,80.2707],12);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
let markers=[];

// PAGE SWITCH
function openMapPage(){ document.getElementById("homePage").classList.remove("active");
                        document.getElementById("mapPage").classList.add("active");
                        renderTable(); setTimeout(()=>map.invalidateSize(),300); renderMap(); }
function goHome(){ document.getElementById("mapPage").classList.remove("active");
                  document.getElementById("homePage").classList.add("active"); }

// VOICE INPUT
function startVoice(fieldId){
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if(!SpeechRecognition){ alert("Voice not supported"); return; }
  let recog = new SpeechRecognition();
  recog.lang='en-US';
  recog.onresult = e=>{ document.getElementById(fieldId).value = e.results[0][0].transcript; };
  recog.start();
}

// Show/hide manual location input
document.getElementById("locationSource").addEventListener("change", function(){
  document.getElementById("manualLocation").style.display = this.value === "manual" ? "block" : "none";
});

// Photo preview
document.getElementById("photoInput").addEventListener("change", function(event){
  const file = event.target.files[0];
  if(file){
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.getElementById("photoPreview");
      img.src = e.target.result;
      img.style.display = "block";
    }
    reader.readAsDataURL(file);
  }
});

// GET COORDS
async function getCoords(location){
  const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${location}`);
  const data = await res.json();
  if(!data.length) return null;
  return {lat: parseFloat(data[0].lat), lng: parseFloat(data[0].lon)};
}

// ADD COMPLAINT
async function addComplaint(){
  let title=document.getElementById("title").value || "No Title";
  let desc=document.getElementById("desc").value || "No Description";
  const file = document.getElementById("photoInput").files[0];

  if(!file){ alert("Attach a photo"); return; }

  let coords = null;
  const locationChoice = document.getElementById("locationSource").value;

  if(locationChoice === "current"){
    if(!navigator.geolocation){ alert("GPS not supported"); return; }
    coords = await new Promise((resolve,reject)=>{
      navigator.geolocation.getCurrentPosition(p => resolve({lat:p.coords.latitude, lng:p.coords.longitude}), e=>reject(e));
    });
  } else if(locationChoice === "manual"){
    const manual = document.getElementById("manualLocation").value;
    if(!manual){ alert("Enter location"); return; }
    coords = await getCoords(manual);
    if(!coords){ alert("Manual location not found"); return; }
  }

  // Store complaint
  complaints.unshift({
    title, desc,
    lat: coords.lat,
    lng: coords.lng,
    photoName: file.name,
    photoData: await new Promise(resolve=>{
      const reader = new FileReader();
      reader.onload = e=>resolve(e.target.result);
      reader.readAsDataURL(file);
    }),
    status:"Pending",
    escalate:0,
    score:0,
    deadline:new Date(new Date().getTime()+60000)
  });
  localStorage.setItem("complaints", JSON.stringify(complaints));

  // Update stats based on title
  let t = title.toLowerCase();
  if(t.includes("dengue")) stats["Dengue"].people+=50;
  else if(t.includes("flood")) stats["Flood"].people+=100;
  else if(t.includes("water")) stats["Water"].people+=40;
  else if(t.includes("garbage")) stats["Garbage"].people+=10;
  else if(t.includes("street")) stats["Street"].people+=5;
  else if(t.includes("pothole")) stats["Pothole"].people+=8;

  updateUI(); renderComplaints(); renderTable(); renderMap();

  // Reset
  document.getElementById("title").value="";
  document.getElementById("desc").value="";
  document.getElementById("photoInput").value="";
  document.getElementById("photoPreview").style.display="none";
  document.getElementById("manualLocation").value="";
}

// UPDATE DASHBOARD
function updateUI(){
  let p=0,e=0,r=0,re=0;
  complaints.forEach(c=>{
    if(c.status==="Pending") p++;
    else if(c.status==="Escalated") e++;
    else if(c.status==="Resolved") r++;
    else if(c.status==="Reopened") re++;
  });
  document.getElementById("pending").innerText=p;
  document.getElementById("escalated").innerText=e;
  document.getElementById("resolved").innerText=r;
  document.getElementById("reopened").innerText=re;
}

// RENDER COMPLAINTS LIST
function renderComplaints(){
  let list = document.getElementById("list"); 
  list.innerHTML="";
  complaints.forEach((c,i)=>{
    let remaining = Math.max(0, Math.floor((new Date(c.deadline) - new Date())/1000));
    let div = document.createElement("div"); 
    div.className="card";
    let photoTag = c.photoData ? `<br><img src="${c.photoData}" style="max-height:120px; border-radius:8px;">` : '';
    
    div.innerHTML = `<h3>${c.title}</h3>
                     <p>${c.desc}</p>
                     <small>${c.lat.toFixed(5)}, ${c.lng.toFixed(5)}</small>${photoTag}<br>
                     <b>Status:</b> ${c.status}<br>
                     <b>Escalation:</b> ${c.escalate}<br>
                     <b>Neglect Score:</b> ${c.score}<br>
                     <b>Time Left:</b> ${remaining}s<br>
                     <button class="btn-green" onclick="resolve(${i})">Resolve</button>
                     <button class="btn-yellow" onclick="reject(${i})">Reject</button>
                     <button class="btn-green" onclick="sendWhatsApp(${i})">WhatsApp</button>`;
    list.appendChild(div);
  });
} 

// --- SUGARCOATED FALLBACK MESSAGES ---
const fallbackMessages = [
  "Oops! I didn’t quite catch that. Could you please rephrase it?",
  "No worries! Let’s try that again, I’m sure we’ll get it right this time.",
  "I see what you mean! Let me think… okay, here’s what I suggest.",
  "Hang tight! I’m working on your question and will get back to you in a moment.",
  "Looks like we hit a tiny snag. But don’t worry, we’ll sort it out together!",
  "Thanks for your patience! I’ve got an answer that might help.",
  "I might need a little more info to help you perfectly. Can you clarify a bit?",
  "You’re doing great! Let’s tackle this question together.",
  "I really appreciate your input! Here’s what I think about that…",
  "Almost there! Here’s a suggestion I hope makes things clearer."
];

// --- FUNCTION TO GET AI REPLY ---
async function getAIReply(userMessage) {
    try {
        const response = await fetch("https://api.openai.com/v1/chat/completions", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "Authorization": "Bearer YOUR_OPENAI_API_KEY" // <-- replace with your key
            },
            body: JSON.stringify({
                model: "gpt-3.5-turbo",
                messages: [{ role: "user", content: userMessage }],
                max_tokens: 250
            })
        });

        const data = await response.json();
        // Use AI reply if exists, else fallback message
        return data.choices?.[0]?.message?.content?.trim() 
               || fallbackMessages[Math.floor(Math.random()*fallbackMessages.length)];
    } catch(err) {
        console.error(err);
        // Return a random sugarcoated message on error
        return fallbackMessages[Math.floor(Math.random()*fallbackMessages.length)];
    }
}

// --- FUNCTION TO DISPLAY CHAT ---
async function sendMessage() {
    const input = document.getElementById("chatInput");
    const message = input.value.trim();
    if(!message) return;

    addChatBubble("user", message); // Show user message
    input.value = "";

    const reply = await getAIReply(message);
    addChatBubble("ai", reply); // Show AI reply
}

// --- FUNCTION TO ADD BUBBLE ---
function addChatBubble(sender, text) {
    const container = document.getElementById("chatContainer");
    const div = document.createElement("div");
    div.className = sender === "user" ? "bubble user" : "bubble ai";
    div.innerText = text;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
} 


// WHATSAPP FUNCTION
function sendWhatsApp(i){
  let c = complaints[i];
  let phoneNumber = "917845896736"; // Replace with your official number
  let message = `🚨 CivicPulse Complaint 🚨%0A
                 Title: ${c.title}%0A
                 Issue: ${c.desc}%0A
                 Location: ${c.lat.toFixed(5)}, ${c.lng.toFixed(5)}`;
  window.open(`https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`, "_blank");
}  



// ESCALATION LOOP
setInterval(()=>{
  let now=new Date();
  complaints = complaints.map(c=>{
    if((c.status==="Pending"||c.status==="Reopened") && now>new Date(c.deadline)){
      return {...c, status:"Escalated", escalate:c.escalate+1, deadline:new Date(now.getTime()+60000)};
    }
    return c;
  });
  updateUI(); renderComplaints();
},1000);

// RESOLVE / REJECT
function resolve(i){ complaints[i].status="Resolved"; updateUI(); renderComplaints(); }
function reject(i){ complaints[i].status="Reopened"; complaints[i].score+=2; updateUI(); renderComplaints(); }

// RENDER TABLE
function renderTable(){
  let body = document.getElementById("dataBody"); body.innerHTML="";
  for(let key in stats){
    let item = stats[key];
    let cls = item.people>1000?"high-risk":item.people>300?"medium-risk":"low-risk";
    body.innerHTML+=`<tr class="${cls}"><td>${key}</td><td>₹${item.cost.toLocaleString()}</td><td>${item.people}</td></tr>`;
  }
}

// RENDER MAP
function renderMap(){
  markers.forEach(m=>map.removeLayer(m)); markers=[];
  complaints.forEach(c=>{
    let marker = L.marker([c.lat,c.lng]).addTo(map)
                  .bindPopup(`<b>${c.title}</b><br>${c.desc}<br>${c.photoData ? '<img src="'+c.photoData+'" style="width:100px;border-radius:8px;">':''}`);
    markers.push(marker);
  });
}

// INITIAL LOAD
updateUI(); renderComplaints(); renderTable(); renderMap();
</script>
</body>
</html>
